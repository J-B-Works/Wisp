@startuml

left to right direction

' --- Dispositivo do Usuário ---
node "<<device>>\nDispositivo do Usuário" as user_device {
    node "<<node>>\nNavegador Web" as browser {
        artifact "Frontend da Plataforma\n(JS/HTML/CSS)" as frontend
    }
}

' --- Nuvem AWS ---
node "Nuvem AWS" as aws {
    node "<<node>>\nServidor de Aplicação " as AppServer {
        artifact "Backend / Recomendador\n(Java)" as backend
    }
    
    node "<<node>>\nServidor de Banco de Dados (RDS)" as rds {
        database "Banco de Dados\n(SQL)" as db
    }
}

' --- Infraestrutura API do mapbox ---
node "<<node>>\nInfraestrutura Mapbox" as mapbox {
    component "API do Mapbox" as mapbox_api
}

' --- Relacionamentos / Protocolos ---
frontend -- backend : HTTP/JSON
backend -- db : TCP/IP 
backend -- mapbox_api : HTTPS/JSON

@enduml